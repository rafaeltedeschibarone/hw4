<!DOCTYPE html>
<html>
  <head>
    <title>Tacostagram Final</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/stylesheets/application.css">
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">Travel Journal</a>
        <div class="ms-auto d-flex align-items-center gap-2">
          <% if current_user %>
            <span class="navbar-text text-white"><%= current_user["username"] %></span>
            <%= button_to "Logout", logout_path, method: :delete, class: "btn btn-outline-light btn-sm" %>
          <% else %>
            <a href="/login" class="btn btn-outline-light btn-sm">Login</a>
            <a href="/users/new" class="btn btn-light btn-sm">Signup</a>
          <% end %>
        </div>
      </div>
    </nav>

    <% if flash["notice"] %>
      <div class="container">
        <div class="alert alert-info"><%= flash["notice"] %></div>
      </div>
    <% end %>

    <div class="container">
      <%= yield %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
